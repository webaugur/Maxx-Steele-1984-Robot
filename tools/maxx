#!/usr/bin/env python3
"""Unified Maxx Steele command-line toolchain.

Dispatches to the Rust `maxx` binary (tools/maxxbas/). Rebuilds release when
sources are newer than the binary (see tools/maxx_build.py).

  maxx compile program.bas -o program.532
  maxx check program.bas
  maxx validate program.532
  maxx list program.532 [--json]
  maxx upload program.bas --device maxx_cart
  maxx simulate program.532 [--json] [--image-out sim.bin]

Agents: run `python3 tools/ensure_maxx_built` before telling the user to launch
the GUI after code changes.
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

from maxx_build import binary_version, build_maxx, ensure_maxx_built, find_maxx_binary
from process_util import main_guard, run
from project_paths import project_root


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--debug-build", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--no-build", action="store_true", help=argparse.SUPPRESS)
    args, rest = parser.parse_known_args(list(argv) if argv is not None else None)
    if rest and rest[0] == "sim":
        rest = ["simulate", *rest[1:]]

    if args.no_build:
        binary = find_maxx_binary()
        if binary is None:
            print(
                "error: maxx binary not found; run without --no-build or "
                "python3 tools/ensure_maxx_built",
                file=sys.stderr,
            )
            return 1
    elif args.debug_build:
        binary = find_maxx_binary() or build_maxx(release=False)
    else:
        binary = ensure_maxx_built()

    env = os.environ.copy()
    tools_dir = str(project_root() / "tools")
    env["PATH"] = f"{tools_dir}{os.pathsep}{env.get('PATH', '')}"

    if rest[:2] == ["simulate", "--gui"] or (
        len(rest) >= 2 and rest[0] == "simulate" and "--gui" in rest[1:]
    ):
        ver = binary_version(binary)
        if ver:
            print(f"using {ver} ({binary})", file=sys.stderr)

    return run([str(binary), *rest], env=env, interrupt_msg="Interrupted.")


if __name__ == "__main__":
    main_guard(main)